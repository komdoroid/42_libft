#include "libft.h"

static int	get_head(char const *s1, char const *set)
{
	size_t	s1len;
	size_t	setlen;
	size_t	head;
	size_t	i;

	s1len = ft_strlen(s1);
	setlen = ft_strlen(set);
	head = 0;
	while (head < s1len)
	{
		i = 0;
		while (i < setlen)
		{
			if (s1[head] == set[i])
				break;
			i++;
		}
		if (i == setlen)
			break;
		head++;
	}
	return (head);
}

static int	get_tail(char const *s1, char const *set)
{
	size_t	s1len;
	size_t	setlen;
	size_t	tail;
	size_t	i;

	s1len = ft_strlen(s1);
	setlen = ft_strlen(set);
	tail = s1len - 1
	while (tail >= 0)
	{
		i = 0;
		while (i < setlen)
		{
			if (s1[tail] == set[i])
				break;
			i++;
		}
		if (i == setlen)
			break;
		tail--;
	}
}

char	*ft_strtrim(char const *s1, char const *set)
{
	char	*trim;
	size_t	head;
	size_t	tail;
	size_t	i;
	size_t	slen;

	if (s1 == NULL)
		return (NULL);
	if (set == NULL)
		return (s1);
	head = get_head(s1, set);
	tail = get_tail(s1, set);
	trim = (char *)malloc(sizeof(char) * ((tail - head  + 1) + 1));
	if (trim == NULL)
		return (NULL);
	i = 0;
	while (i <= tail - head)
	{
		trim[i] = s1[i + head];
		i++;
	}
	trim[i] = '\0';
	return (trim);
}

